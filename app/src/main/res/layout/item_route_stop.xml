<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="24dp"
    android:paddingEnd="16dp">

    <!-- Timeline Line -->
    <View
        android:id="@+id/timelineLine"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@color/accent_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/stopIconContainer"
        app:layout_constraintEnd_toEndOf="@+id/stopIconContainer"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Stop Icon Container -->
    <FrameLayout
        android:id="@+id/stopIconContainer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/status_indicator_green"
        android:backgroundTint="#E1E5ED"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/stopIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nfc"
            app:tint="@color/dark_blue_header" />
    </FrameLayout>

    <!-- Stop Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/stopIconContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/stopIconContainer"
        app:layout_constraintTop_toTopOf="@+id/stopIconContainer">

        <TextView
            android:id="@+id/stopName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_blue_header"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/arrivalStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="NEXT BUS: 2 MIN"
            android:textColor="@color/accent_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/stopAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4th &amp; Main Ave"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>